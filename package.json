{
  "name": "vybe-cabs-driver-allocation",
  "version": "1.0.0",
  "description": "Real-Time Driver Allocation System for vybe cabs",
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "mkdirp dist/common/redis/lua && cpy \"src/common/redis/lua/*.lua\" dist/common/redis/lua",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:prod": "node dist/main.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/typeorm.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/typeorm.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/typeorm.config.ts",
    "verify:concurrency": "ts-node scripts/verify-concurrency.ts",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "axios": "^1.7.2",
    "cpy-cli": "^5.0.0",
    "jest": "^29.7.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^5.0.9",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
